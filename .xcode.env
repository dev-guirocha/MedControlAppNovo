# Environment overrides for Xcode build scripts
# Ensures Node and UTF-8 are available inside Xcode Run Script phases

# Adjust if your Node is installed elsewhere
NVM_NODE="$HOME/.nvm/versions/node/v20.19.5/bin/node"
if [ -x "$NVM_NODE" ]; then
  export NODE_BINARY="$NVM_NODE"
else
  export NODE_BINARY="/opt/homebrew/bin/node"
fi

# Broaden PATH for Homebrew/asdf/NVM (edit to match your setup if needed)
export PATH="$HOME/.npm-global/bin:$HOME/.asdf/shims:/opt/homebrew/bin:$PATH"

# Avoid CocoaPods UTF-8 warning
export LANG=en_US.UTF-8
