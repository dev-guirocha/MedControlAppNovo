# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
# When using nvm, Xcode's non-interactive shells don't load your profile,
# so we fall back to the currently installed version explicitly.
NVM_NODE="$HOME/.nvm/versions/node/v20.19.5/bin/node"
if [ -x "$NVM_NODE" ]; then
  export NODE_BINARY="$NVM_NODE"
else
  export NODE_BINARY="$(command -v node)"
fi
